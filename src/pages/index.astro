---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import GrainOverlay from '../components/GrainOverlay.astro';
---
<BaseLayout
  title="Johny Francis — Production Technology & GenAI, Netflix APAC"
  description="Senior Manager, Production Technology & Generative AI at Netflix APAC. A creative technologist who builds systems, workflows, and tools that help storytellers do more of what only they can do."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Johny Francis",
    "jobTitle": "Senior Manager, Production Technology & Generative AI",
    "worksFor": { "@type": "Organization", "name": "Netflix" },
    "url": "https://johnyfrancis.com",
    "email": "johnyfrancis@hotmail.com",
    "sameAs": ["https://linkedin.com/in/johnyfrancis"]
  })} />

  <!-- Hero -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-bg" aria-hidden="true"></div>
    <GrainOverlay />
    <div class="hero-inner">
      <div class="hero-eyebrow fade-up">Senior Manager, Production Technology &amp; GenAI — Netflix APAC</div>
      <div class="hero-salutation fade-up fade-up-1">Hello, I'm</div>
      <div class="hero-name-wrap fade-up fade-up-2">
        <h1 class="hero-name">Johny.</h1>
      </div>
      <div class="hero-body fade-up fade-up-3">
        <p>I think a lot.</p>
        <p>Then I build something.</p>
        <p>Sometimes a story. Sometimes a system.</p>
        <p class="hero-sub">At the intersection of creativity and technology, the best work happens when the tools disappear and the vision stays.</p>
      </div>
      <!-- Curved annotation arrow + CTA -->
      <div class="hero-cta-wrap fade-up fade-up-4">
        <svg class="deco-arrow" viewBox="0 0 52 46" fill="none" aria-hidden="true" focusable="false">
          <path d="M6 40 C8 24, 24 11, 46 8" stroke="#E8A87C" stroke-width="1.4" stroke-linecap="round"/>
          <path d="M40 3 L46 8 L40 14" stroke="#E8A87C" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="hero-cta">
          <Button href="/about/">Read my story →</Button>
          <Button href="/work/" variant="ghost">See my work →</Button>
        </div>
      </div>
    </div>
    <div class="hero-scroll fade-up fade-up-5" aria-hidden="true">
      <span></span>
      Scroll
    </div>
  </section>

  <!-- Three things that are true -->
  <section class="three-things" aria-label="Three things that are true">
    <div class="three-things-inner">
      <div class="three-things-grid">
        <div class="truth-item reveal">
          <span class="truth-icon" aria-hidden="true">🎬</span>
          <h2 class="truth-label">Creative Partner</h2>
          <p class="truth-body">Started as a photographer. Trained as a cinematographer. Spent years on film sets working alongside cinematographers and directors — understanding how they see, how they think, and what gets in the way of their vision.</p>
        </div>
        <div class="truth-item reveal reveal-d1">
          <span class="truth-icon" aria-hidden="true">⚙️</span>
          <h2 class="truth-label">Builds processes, products, and systems</h2>
          <p class="truth-body">Sometimes using AI. Always in service of helping creators get their vision and story to life.</p>
        </div>
        <div class="truth-item reveal reveal-d2">
          <span class="truth-icon" aria-hidden="true">🧠</span>
          <h2 class="truth-label">Systems Thinking. Design Thinking. Human Instinct.</h2>
          <p class="truth-body">Technology is only as good as the people it serves. That never changes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quiet CTA strip -->
  <section class="cta-strip" aria-label="Quick links">
    <div class="cta-strip-inner reveal">
      <p class="cta-strip-line">I work with filmmakers, directors, cinematographers, and creative teams to bring stories to life — across Asia Pacific and beyond.</p>
      <nav class="cta-strip-links" aria-label="Quick navigation">
        <a href="/about/">Read my story</a>
        <span class="cta-dot" aria-hidden="true">·</span>
        <a href="/work/">See my work</a>
        <span class="cta-dot" aria-hidden="true">·</span>
        <a href="/contact/">Get in touch</a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 8rem 3rem 5rem;
  position: relative;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 80% 40%, rgba(74,124,142,0.13) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 15% 80%, rgba(232,168,124,0.07) 0%, transparent 60%);
}
.hero-inner { position: relative; max-width: 980px; width: 100%; margin: 0 auto; }
.hero-eyebrow {
  font-family: 'Lora', serif;
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-teal-light);
  opacity: 0.8;
  margin-bottom: 2rem;
}
.hero-salutation {
  font-family: 'Crimson Pro', serif;
  font-size: 1.1rem;
  font-style: italic;
  font-weight: 300;
  color: var(--color-sand);
  opacity: 0.4;
  margin-bottom: 0.2rem;
}
.hero-name-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 1.25rem;
}
.hero-name {
  font-family: 'Caveat', cursive;
  font-style: normal;
  font-size: clamp(36px, 5vw, 64px);
  color: var(--color-sand);
  line-height: 1;
  letter-spacing: -0.01em;
}
.hero-name-svg {
  position: absolute;
  bottom: -10px;
  left: 0;
  width: 100%;
  height: 16px;
}
.hero-body {
  font-size: clamp(1.1rem, 2vw, 1.3rem);
  color: var(--color-sand);
  opacity: 0.62;
  line-height: 1.8;
  max-width: 560px;
  margin-bottom: 2.5rem;
}
.hero-body p { margin-bottom: 0.1rem; }
.hero-sub {
  margin-top: 1.2rem !important;
  opacity: 0.85;
  font-size: clamp(calc(0.95rem + 2px), 1.5vw, calc(1.1rem + 2px)) !important;
  line-height: 1.75;
}
/* ── Hand-drawn decoration animations ── */
@keyframes drawStroke {
  from { stroke-dashoffset: var(--len, 600); }
  to   { stroke-dashoffset: 0; }
}

/* Name underline — draws in after hero-name fades up (fade-up-2 starts 0.2s) */
.name-stroke-1 {
  stroke-dasharray: 600;
  stroke-dashoffset: 600;
  animation: drawStroke 1s cubic-bezier(0.4, 0, 0.2, 1) 0.8s both;
  --len: 600;
}
.name-stroke-2 {
  stroke-dasharray: 600;
  stroke-dashoffset: 600;
  animation: drawStroke 1.4s cubic-bezier(0.4, 0, 0.2, 1) 1s both;
  --len: 600;
}

/* Story-line squiggle underline */
.story-line { display: block; }
.deco-squiggle {
  display: block;
  width: 100%;
  max-width: 300px;
  height: 9px;
  margin-top: 0.2rem;
}
.deco-squiggle path {
  stroke-dasharray: 330;
  stroke-dashoffset: 330;
  animation: drawStroke 0.9s cubic-bezier(0.4, 0, 0.2, 1) 1.1s both;
  --len: 330;
}

/* CTA wrap — arrow + buttons inline */
.hero-cta-wrap { display: flex; align-items: flex-end; gap: 0; }
.deco-arrow {
  width: 52px;
  height: 46px;
  margin-right: 0.5rem;
  margin-bottom: 0.5rem;
  flex-shrink: 0;
  opacity: 0.7;
}
.deco-arrow path {
  stroke-dasharray: 100;
  stroke-dashoffset: 100;
  animation: drawStroke 0.7s cubic-bezier(0.4, 0, 0.2, 1) 1.3s both;
  --len: 100;
}
.hero-cta { display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap; }

.hero-scroll {
  position: absolute;
  bottom: 2.5rem;
  left: 3rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-family: 'Lora', serif;
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-sand);
  opacity: 0.4;
}
.hero-scroll span { display: block; width: 28px; height: 0.5px; background: var(--color-sand); opacity: 0.7; }

.three-things {
  background: var(--color-navy);
  border-top: 0.5px solid rgba(245,237,216,0.04);
  padding: 6rem 3rem;
}
.three-things-inner { max-width: 980px; margin: 0 auto; }

/* Section header with hand-drawn teal underline */
.three-things-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.35rem;
  margin-bottom: 3rem;
}
.three-things-label {
  font-family: 'Lora', serif;
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-teal-light);
  opacity: 0.7;
}
.deco-section-line {
  width: 220px;
  height: 10px;
}
.deco-section-line path {
  stroke-dasharray: 240;
  stroke-dashoffset: 240;
  transition: stroke-dashoffset 0.9s cubic-bezier(0.4, 0, 0.2, 1) 0.3s;
}
.three-things-header.visible .deco-section-line path { stroke-dashoffset: 0; }

.three-things-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem; }
.truth-icon { font-size: 1.5rem; display: block; margin-bottom: 1rem; }
.truth-label {
  font-family: 'DM Serif Display', serif;
  font-size: 1.1rem;
  color: var(--color-sand);
  margin-bottom: 0.75rem;
  line-height: 1.3;
}
.truth-body { font-size: 0.95rem; color: var(--color-sand); opacity: 0.5; line-height: 1.7; }

.cta-strip {
  background: var(--color-navy-deep);
  border-top: 0.5px solid rgba(245,237,216,0.04);
  padding: 4rem 3rem;
}
.cta-strip-inner {
  max-width: 980px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
  text-align: center;
}
/* Oval annotation around CTA heading */
.cta-heading-wrap {
  position: relative;
  display: inline-block;
  padding: 0.5rem 1.5rem;
}
.deco-oval {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: visible;
  pointer-events: none;
}
.deco-oval path {
  stroke-dasharray: 800;
  stroke-dashoffset: 800;
  transition: stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1) 0.35s;
}
.cta-strip-inner.visible .deco-oval path { stroke-dashoffset: 0; }

.cta-strip-line {
  font-family: 'DM Serif Display', serif;
  font-style: italic;
  font-size: clamp(1.2rem, 2.5vw, 1.6rem);
  color: var(--color-sand);
  opacity: 0.45;
}
.cta-strip-links { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; justify-content: center; }
.cta-strip-links a {
  font-family: 'Lora', serif;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-coral);
  opacity: 0.65;
  text-decoration: none;
  transition: opacity 0.2s;
}
.cta-strip-links a:hover { opacity: 1; }
.cta-dot { color: var(--color-sand); opacity: 0.2; }

@media (max-width: 768px) {
  .hero { padding: 7rem 1.5rem 4rem; }
  .hero-scroll { left: 1.5rem; }
  .three-things { padding: 4rem 1.5rem; }
  .three-things-grid { grid-template-columns: 1fr; gap: 2rem; }
  .cta-strip { padding: 3rem 1.5rem; }
  .deco-arrow { display: none; }
  .deco-oval { width: 260px; }
}
</style>
