---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found — Johny Francis" description="This page doesn't exist.">
  <section style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 4rem 1.5rem; text-align: center;">
    <div>
      <p style="font-family: var(--font-ui); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-teal-light); margin-bottom: 1.5rem;">404</p>
      <h1 style="font-family: 'Caveat', cursive; font-size: clamp(36px, 5vw, 64px); color: var(--color-sand); margin-bottom: 1.5rem;">This page doesn't exist.</h1>
      <a href="/" style="font-family: var(--font-ui); font-size: 0.875rem; color: var(--color-coral); text-decoration: none; letter-spacing: 0.05em;">← Back home</a>
    </div>
  </section>
</BaseLayout>
