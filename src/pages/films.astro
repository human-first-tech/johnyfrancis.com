---
<BaseLayout
  title="Films — Johny Francis"
  description="A selection of films and shows I've contributed to across imaging, post-production, and production technology."
>
  <section class="films-hero" aria-label="Page header">
    <GrainOverlay />
    <div class="films-hero-inner">
      <p class="films-eyebrow">Films</p>
      <h1 class="films-title">The work that made it to screen.</h1>
      <p class="films-tagline">A selection of films and shows I had the privilege of working on.</p>
    </div>
  </section>

  <section class="films-grid-section" aria-label="Filmography">
    <div class="films-col">
      {films.length === 0 ? (
        <div class="films-empty">
          <p>Posters coming soon.</p>
        </div>
      ) : (
        <ul class="films-grid">
          {films.map(f => (
            <li class="film-tile reveal">
              {f.link ? (
                <a href={f.link} target="_blank" rel="noopener noreferrer" aria-label={`${f.title} (${f.year})`}>
                  <div class="film-poster">
                    <img src={f.poster} alt={`${f.title} poster`} loading="lazy" />
                  </div>
                  <div class="film-meta">
                    <h2 class="film-title">{f.title}</h2>
                    <div class="film-sub">
                      <span class="film-year">{f.year}</span>
                      {f.role && <span class="film-role"> · {f.role}</span>}
                    </div>
                  </div>
                </a>
              ) : (
                <>
                  <div class={`film-poster ${!f.poster ? 'film-poster--empty' : ''}`}>
                    {f.poster ? (
                      <img src={f.poster} alt={`${f.title} poster`} loading="lazy" />
                    ) : (
                      <span class="film-poster-fallback">{f.title}</span>
                    )}
                  </div>
                  <div class="film-meta">
                    <h2 class="film-title">{f.title}</h2>
                    <div class="film-sub">
                      <span class="film-year">{f.year}</span>
                      {f.role && <span class="film-role"> · {f.role}</span>}
                    </div>
                  </div>
                </>
              )}
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
.films-hero {
  min-height: 38vh;
  display: flex;
  align-items: flex-end;
  padding: 9rem 3rem 4rem;
  position: relative;
  background: var(--color-navy);
  overflow: hidden;
}
.films-hero-inner { position: relative; max-width: 980px; width: 100%; }
.films-eyebrow {
  font-family: 'Lora', serif;
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-teal-light);
  opacity: 0.7;
  margin-bottom: 1rem;
}
.films-title {
  font-family: 'Caveat', cursive;
  font-style: normal;
  font-size: clamp(36px, 5vw, 64px);
  color: var(--color-sand);
  line-height: 1.1;
  margin-bottom: 1rem;
}
.films-tagline {
  font-family: 'Lora', serif;
  font-size: 0.95rem;
  color: var(--color-sand);
  opacity: 0.55;
  max-width: 580px;
}

.films-grid-section {
  background: var(--color-navy-deep);
  padding: 5rem 0 7rem;
}
.films-col { max-width: 1200px; margin: 0 auto; padding: 0 3rem; }

.films-empty {
  text-align: center;
  padding: 4rem 0;
  font-family: 'Lora', serif;
  font-size: 0.9rem;
  color: var(--color-sand);
  opacity: 0.4;
  letter-spacing: 0.05em;
}

.films-grid {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 2rem 1.5rem;
}

.film-tile { position: relative; }
.film-tile a {
  display: block;
  text-decoration: none;
  color: inherit;
}

.film-poster {
  position: relative;
  aspect-ratio: 2 / 3;
  overflow: hidden;
  border-radius: 4px;
  background: rgba(245,237,216,0.04);
  box-shadow: 0 6px 24px rgba(0,0,0,0.35);
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}
.film-poster img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}
.film-tile:hover .film-poster {
  transform: translateY(-4px);
  box-shadow: 0 14px 36px rgba(0,0,0,0.55);
}
.film-tile:hover .film-poster img { transform: scale(1.03); }

.film-poster--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
  background: linear-gradient(160deg, rgba(74,124,142,0.18), rgba(232,168,124,0.08));
  border: 0.5px solid rgba(245,237,216,0.08);
}
.film-poster-fallback {
  font-family: 'DM Serif Display', serif;
  font-size: 0.95rem;
  color: var(--color-sand);
  opacity: 0.7;
  text-align: center;
  line-height: 1.25;
}

.film-meta { padding: 0.9rem 0.1rem 0; }
.film-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.05rem;
  color: var(--color-sand);
  line-height: 1.25;
  margin: 0 0 0.25rem;
}
.film-sub {
  font-family: 'Lora', serif;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-teal-light);
  opacity: 0.6;
}
.film-role { opacity: 0.85; }

@media (max-width: 768px) {
  .films-hero { padding: 7rem 1.5rem 3rem; min-height: 28vh; }
  .films-col { padding: 0 1.5rem; }
  .films-grid {
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 1.5rem 1rem;
  }
}
</style>
