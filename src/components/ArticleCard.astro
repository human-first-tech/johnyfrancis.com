---
interface Props {
  number: string;
  title: string;
  dek: string;
  readTime: string;
  href: string;
}
const { number, title, dek, readTime, href } = Astro.props;
---
<a href={href} class="article-card">
  <span class="article-card-num">{number}</span>
  <div class="article-card-content">
    <h3 class="article-card-title">{title}</h3>
    <p class="article-card-dek">{dek}</p>
    <span class="article-card-meta">{readTime}</span>
  </div>
  <span class="article-card-arrow" aria-hidden="true">→</span>
</a>

<style>
.article-card {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 1.5rem;
  align-items: baseline;
  padding: 1.75rem 0;
  border-bottom: 0.5px solid rgba(245, 237, 216, 0.07);
  text-decoration: none;
  transition: padding-left 0.25s;
}
.article-card:first-of-type { border-top: 0.5px solid rgba(245, 237, 216, 0.07); }
.article-card:hover { padding-left: 0.6rem; }
.article-card-num {
  font-family: 'Lora', serif;
  font-size: 0.65rem;
  letter-spacing: 0.16em;
  color: var(--color-coral);
  opacity: 0.5;
  align-self: start;
  padding-top: 0.3rem;
}
.article-card-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.15rem;
  color: var(--color-sand);
  margin-bottom: 0.3rem;
  line-height: 1.3;
  transition: color 0.2s;
}
.article-card:hover .article-card-title { color: var(--color-coral); }
.article-card-dek {
  font-size: 0.92rem;
  color: var(--color-sand);
  opacity: 0.42;
  font-style: italic;
  line-height: 1.5;
  margin-bottom: 0.5rem;
}
.article-card-meta {
  font-family: 'Lora', serif;
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  color: var(--color-sand);
  opacity: 0.25;
}
.article-card-arrow {
  font-size: 1rem;
  color: var(--color-coral);
  opacity: 0.3;
  align-self: center;
  transition: opacity 0.2s, transform 0.2s;
}
.article-card:hover .article-card-arrow {
  opacity: 0.8;
  transform: translateX(4px);
}
</style>
