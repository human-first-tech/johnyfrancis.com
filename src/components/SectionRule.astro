---
interface Props {
  number: string;
  label: string;
}
const { number, label } = Astro.props;
---
<div class="section-rule" role="presentation">
  <span class="section-num">{number}</span>
  <span class="section-title">{label}</span>
  <div class="section-line" aria-hidden="true"></div>
</div>

<style>
.section-rule {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 3.5rem;
}
.section-num {
  font-family: 'Lora', serif;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  color: var(--color-coral);
  opacity: 0.65;
  flex-shrink: 0;
}
.section-title {
  font-family: 'Lora', serif;
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-sand);
  opacity: 0.28;
  flex-shrink: 0;
}
.section-line {
  flex: 1;
  height: 0.5px;
  background: rgba(245, 237, 216, 0.07);
}
</style>
