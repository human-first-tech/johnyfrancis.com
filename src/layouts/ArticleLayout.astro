---
import '../styles/global.css';

interface Props {
  title: string;
  dek: string;
  number: string;
  readTime: string;
  date: string;
  prevSlug?: string;
  prevTitle?: string;
  nextSlug?: string;
  nextTitle?: string;
}

const { title, dek, number, readTime, date, prevSlug, prevTitle, nextSlug, nextTitle } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = `${title} — Johny Francis`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={dek} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={dek} />
  <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="#article-content" class="skip-link">Skip to content</a>

  <nav class="article-nav" role="navigation" aria-label="Article navigation">
    <a href="/" class="article-nav-logo" aria-label="Johny Francis — home">
      Johny Francis
      <svg viewBox="0 0 120 8" fill="none" aria-hidden="true" focusable="false">
        <path d="M2 5 C18 2, 38 7, 58 4 S88 1, 108 5 S118 6, 118 4" stroke="#E8A87C" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </a>
    <a href="/thinking/" class="article-nav-back">← Back to Thinking</a>
  </nav>

  <main id="article-content">
    <header class="article-header">
      <div class="article-header-inner">
        <p class="article-eyebrow">{number} · Thinking</p>
        <h1 class="article-title">{title}</h1>
        <p class="article-dek">{dek}</p>
        <p class="article-meta">{readTime} · {date}</p>
      </div>
    </header>

    <article class="article-body">
      <div class="prose-johny article-prose">
        <slot />
      </div>
    </article>

    <section class="article-bio" aria-label="Author bio">
      <p class="bio-text"><em>Johny Francis</em> is a Senior Manager of Production Technology and Generative AI at Netflix APAC. His career spans film sets, camera technology, virtual production, and AI systems. He teaches at FTI, SRFTI, and Whistling Woods International.</p>
    </section>

    <nav class="article-prevnext" aria-label="Previous and next articles">
      {prevSlug && (
        <a href={`/thinking/${prevSlug}/`} class="prevnext-item prevnext-prev">
          <span class="prevnext-label">Previous</span>
          <span class="prevnext-title">{prevTitle}</span>
        </a>
      )}
      {!prevSlug && <div class="prevnext-item prevnext-empty"></div>}
      {nextSlug && (
        <a href={`/thinking/${nextSlug}/`} class="prevnext-item prevnext-next">
          <span class="prevnext-label">Next</span>
          <span class="prevnext-title">{nextTitle}</span>
        </a>
      )}
      {!nextSlug && <div class="prevnext-item prevnext-empty"></div>}
    </nav>
  </main>

  <footer class="article-footer" role="contentinfo">
    <a href="/" class="footer-logo">Johny Francis</a>
    <span class="footer-copy">&copy; {new Date().getFullYear()} Johny Francis · Mumbai</span>
  </footer>
</body>
</html>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background-color: #111B28;
  color: #F5EDD8;
  font-family: 'Crimson Pro', Georgia, serif;
  font-weight: 300;
  line-height: 1.7;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
:focus-visible { outline: 2px solid rgba(245,237,216,0.6); outline-offset: 2px; }
.skip-link {
  position: absolute; top: -100%; left: 1rem; z-index: 9999;
  background: #E8A87C; color: #111B28;
  padding: 0.5rem 1rem; border-radius: 4px;
  font-family: 'Lora', serif; font-size: 0.75rem;
  letter-spacing: 0.08em; text-transform: uppercase;
  text-decoration: none; transition: top 0.2s;
}
.skip-link:focus { top: 1rem; }

.article-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 1.25rem 3rem;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(17,27,40,0.9); backdrop-filter: blur(14px);
  border-bottom: 0.5px solid rgba(245,237,216,0.06);
}
.article-nav-logo {
  font-family: 'DM Serif Display', serif;
  font-style: italic; font-size: 1.1rem;
  color: #F5EDD8; text-decoration: none;
  position: relative; display: inline-block;
}
.article-nav-logo svg { position: absolute; bottom: -4px; left: 0; width: 100%; height: 8px; }
.article-nav-back {
  font-family: 'Lora', serif; font-size: 0.7rem;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: #F5EDD8; opacity: 0.35; text-decoration: none;
  transition: opacity 0.2s;
}
.article-nav-back:hover { opacity: 0.8; }

.article-header {
  padding: 8rem 3rem 4rem;
  background: #1A2535;
  border-bottom: 0.5px solid rgba(245,237,216,0.04);
}
.article-header-inner { max-width: 680px; margin: 0 auto; }
.article-eyebrow {
  font-family: 'Lora', serif;
  font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: #6A9BAE; opacity: 0.8; margin-bottom: 1.25rem;
}
.article-title {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(1.8rem, 4vw, 3rem);
  color: #F5EDD8; line-height: 1.15; margin-bottom: 1.1rem;
}
.article-dek {
  font-size: 1.1rem; font-style: italic;
  color: #F5EDD8; opacity: 0.5; line-height: 1.65; margin-bottom: 1rem;
}
.article-meta {
  font-family: 'Lora', serif; font-size: 0.65rem;
  letter-spacing: 0.1em; color: #F5EDD8; opacity: 0.25;
}

.article-body { padding: 4rem 3rem 3rem; background: #111B28; }
.article-prose {
  max-width: 680px;
  margin: 0 auto;
  font-size: 1.12rem;
  line-height: 1.85;
  color: #F5EDD8;
  opacity: 0.72;
}
.article-prose :global(p) { margin-bottom: 1.5rem; }
.article-prose :global(p:last-child) { margin-bottom: 0; }
.article-prose :global(em) { color: #E8A87C; font-style: italic; opacity: 1; }
.article-prose :global(strong) { color: #F5EDD8; font-weight: 600; opacity: 1; }
.article-prose :global(h2), .article-prose :global(h3) {
  font-family: 'DM Serif Display', serif;
  color: #F5EDD8; opacity: 0.9;
  margin: 2.5rem 0 1rem;
  line-height: 1.2;
}
.article-prose :global(h2) { font-size: 1.45rem; }
.article-prose :global(h3) { font-size: 1.2rem; }
.article-prose :global(p:first-of-type::first-letter) {
  font-family: 'DM Serif Display', serif;
  font-style: italic;
  font-size: 3.5rem;
  line-height: 0.85;
  float: left;
  margin-right: 0.08em;
  margin-top: 0.12em;
  color: #E8A87C;
}

.article-bio {
  max-width: 680px;
  margin: 0 auto;
  padding: 0 3rem 3rem;
  background: #111B28;
}
.bio-text {
  font-size: 0.9rem;
  color: #F5EDD8;
  opacity: 0.35;
  line-height: 1.7;
  padding-top: 2rem;
  border-top: 0.5px solid rgba(245,237,216,0.08);
}
.bio-text :global(em) { color: #E8A87C; font-style: italic; opacity: 1; }

.article-prevnext {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: rgba(245,237,216,0.05);
  border-top: 0.5px solid rgba(245,237,216,0.07);
  background: #111B28;
  max-width: 100%;
  padding: 0 3rem;
}
.prevnext-item {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  padding: 2rem 0;
  text-decoration: none;
}
.prevnext-next { align-items: flex-end; text-align: right; }
.prevnext-empty {}
.prevnext-label {
  font-family: 'Lora', serif;
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #F5EDD8;
  opacity: 0.22;
}
.prevnext-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1rem;
  color: #F5EDD8;
  opacity: 0.55;
  line-height: 1.3;
  transition: color 0.2s, opacity 0.2s;
}
.prevnext-item:hover .prevnext-title { color: #E8A87C; opacity: 1; }

.article-footer {
  padding: 1.75rem 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 0.5px solid rgba(245,237,216,0.05);
  background: #111B28;
}
.footer-logo {
  font-family: 'DM Serif Display', serif;
  font-style: italic; font-size: 1rem;
  color: #F5EDD8; opacity: 0.28;
  text-decoration: none;
}
.footer-copy {
  font-family: 'Lora', serif; font-size: 0.65rem;
  letter-spacing: 0.08em; color: #F5EDD8; opacity: 0.18;
}

@keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
@media (prefers-reduced-motion: reduce) {
  * { animation: none !important; transition: none !important; }
}
@media (max-width: 768px) {
  .article-nav { padding: 1rem 1.5rem; }
  .article-header { padding: 7rem 1.5rem 3rem; }
  .article-body { padding: 3rem 1.5rem 2rem; }
  .article-bio { padding: 0 1.5rem 2rem; }
  .article-prevnext { padding: 0 1.5rem; }
  .article-footer { padding: 1.5rem; flex-direction: column; gap: 0.5rem; text-align: center; }
}
</style>
